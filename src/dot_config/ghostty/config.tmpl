########################################
# Fonts
########################################

font-family = ""
font-family = {{.fonts.terminal | quoteList | join "\nfont-family = "}}
font-size = 14

########################################
# Colors
########################################

theme = Nord
window-theme = ghostty

########################################
# Window
########################################

window-height = 48
window-width = 120

window-padding-x = 12
window-padding-y = 12
window-padding-balance = true

########################################
# Keybindings
########################################

# Apply font-size changes to all terminals
keybind = all:ctrl+==increase_font_size:1
keybind = all:ctrl++=increase_font_size:1
keybind = all:ctrl+-=decrease_font_size:1
keybind = all:ctrl+0=reset_font_size

# Focus split
keybind = alt+down=goto_split:down
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:up
