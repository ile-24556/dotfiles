// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "One Dark",
  },

  "buffer_font_family": {{first .fonts.monospace | quote}},
  "buffer_font_fallbacks": [
    {{rest .fonts.monospace | quoteList | join ",\n    "}},
  ],
  "buffer_font_features": {
    "zero": true, // JetBrains Mono: slashed zero
  },
  "buffer_font_size": 24,

  "ui_font_family": {{first .fonts.sansSerif | quote}},
  "ui_font_fallbacks": [
    {{rest .fonts.sansSerif | quoteList | join ",\n    "}},
  ],
  "ui_font_features": {
    "tnum": true, // Inter Variable: tabular numbers
    "cv03": true, // Inter Variable: open six
    "cv04": true, // Inter Variable: open nine
    "cv05": true, // Inter Variable: lower case l with tail
  },
  "ui_font_size": 21,

  "terminal": {
    "font_family": {{first .fonts.terminal | quote}},
    "font_fallbacks": [
      {{rest .fonts.terminal | quoteList | join ",\n      "}},
    ],
    "font_size": 21,
  },

  "show_whitespaces": "boundary",
  "wrap_guides": [80, 100],

  "format_on_save": "off",
  "autosave": "on_focus_change",

  "languages": {
    "Git Commit": {
      "wrap_guides": [50, 72],
    },
  },
}
